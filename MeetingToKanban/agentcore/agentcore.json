{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "MeetingToKanban",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "MeetingToKanban"
  },
  "runtimes": [
    {
      "name": "notion_mcp",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/notion_mcp/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "instrumentation": {
        "enableOtel": false
      },
      "protocol": "MCP"
    },
    {
      "name": "MeetingToKanban_agent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/MeetingToKanban_agent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [
    {
      "name": "MeetingToKanban_agentMemory",
      "eventExpiryDuration": 30,
      "strategies": []
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "MeetingToKanbanGTW",
      "description": "Gateway for MeetingToKanbanGTW",
      "targets": [],
      "authorizerType": "AWS_IAM",
      "enableSemanticSearch": true,
      "exceptionLevel": "NONE"
    }
  ],
  "policyEngines": []
}